{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/ping.ts": {
      "runtime": "nodejs20.x"
    },
    "api/proxy-health.ts": {
      "includeFiles": "shared/**",
      "runtime": "nodejs20.x"
    },
    "api/proxy.ts": {
      "includeFiles": "lib/**",
      "runtime": "nodejs20.x"
    }
  }
}
